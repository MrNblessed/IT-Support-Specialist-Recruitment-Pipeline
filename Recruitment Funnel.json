    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze the following recruitment pipeline metrics:\n\n{{ $json.data }}\n\nTasks:\n\n1. Identify the bottleneck stage (Screening, Interview, or Offer).\n2. Explain why it is the bottleneck.\n3. Provide three actionable recommendations to improve hiring speed.\n4. Return the response as valid HTML only.\n",
        "hasOutputParser": true,
        "needsFallback": true,
        "options": {
          "systemMessage": "=You are a Recruitment Pipeline Analytics Assistant.\n\nYour task is to analyze recruitment pipeline metrics and identify process inefficiencies.\n\nInstructions:\n\n1. Review the provided pipeline metrics.\n2. Determine the bottleneck stage among Screening, Interview, and Offer.\n3. Identify the stage causing the greatest delay or candidate accumulation.\n4. Generate exactly three actionable recommendations to improve hiring speed.\n5. Format the response as valid HTML.\n6. Use <b> tags to highlight key findings.\n7. Use <ul> and <li> tags for recommendations.\n8. Return only the HTML content.\n9. Do not include markdown, code blocks, or explanatory text.\n"
        }
