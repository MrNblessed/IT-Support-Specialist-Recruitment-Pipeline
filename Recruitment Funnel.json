    {
      "parameters": {
        "promptType": "define",
        "text": "=Candidate Name: {{ $('Read: Applicant').item.json.Name }}\n\nCurrent Stage: {{ $('Read: Applicant').item.json['Current Stage'] }}\n\nDays in Stage: {{ $('Read: Applicant').item.json['Days in Stage'] }}\n\nEducation Level: {{ $('Read: Applicant').item.json['Level of Education  '] }}\n\nYears of Experience: {{ $('Read: Applicant').item.json['Years of Experience'] }}\n\nRequired Skills: {{ $json['Required Skills'] }}\n\nCandidate Skills: {{ $('Read: Applicant').item.json.Skills }}\n\nInterview Feedback: {{ $json['Feedback Notes'] }}\nAssessment Tasks:\n\n1. Calculate a Fit Score from 0-100.\n2. Assign a Fit Category (High Fit, Medium Fit, Low Fit).\n3. Estimate the candidate's Time-to-Hire in days.\n4. Determine whether the candidate is Healthy or Stalled.\n5. Identify the primary recruitment risk.\n6. Return the result using the required JSON schema.\n",
        "hasOutputParser": true,
        "needsFallback": true,
        "options": {
          "systemMessage": "You are a Recruitment Analytics AI Agent.\n\nYour responsibilities are:\n\n1. Calculate a Fit Score between 0 and 100 based on:\n\n   * Candidate skills match\n   * Experience relevance\n   * Education alignment\n   * Interview feedback sentiment\n\n2. Determine a Fit Category:\n\n   * 80-100: High Fit\n   * 60-79: Medium Fit\n   * 0-59: Low Fit\n\n3. Analyze hiring progress and estimate Time-to-Hire:\n\n   * Compare the candidate's current days in stage against the expected hiring timeline.\n   * Flag delays when a candidate spends more than 7 days in a stage.\n\n4. Identify recruitment risks such as:\n\n   * Delayed progression\n   * Negative interview feedback\n   * Skill gaps\n   * Missing qualifications\n\n5. Return only valid JSON matching the required schema.\n\nDo not include explanations, markdown, or text outside the JSON response.\n"
        }
      },
